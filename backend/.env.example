# ─── App ──────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Spendly
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000
APP_FRONTEND_CALLBACK_SCHEME=spendly
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:3000,spendly://callback

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://spendly:spendly@localhost:5432/spendly
DATABASE_URL_ASYNC=postgresql+asyncpg://spendly:spendly@localhost:5432/spendly

# ─── Redis / Celery ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── PSD2 provider: GoCardless Bank Account Data (ex-Nordigen) ────────────
# Sign up at https://bankaccountdata.gocardless.com/ and create an app to get these
PSD2_PROVIDER=gocardless
GOCARDLESS_SECRET_ID=YOUR_SECRET_ID
GOCARDLESS_SECRET_KEY=YOUR_SECRET_KEY
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2
GOCARDLESS_DEFAULT_COUNTRY=PL
# How long the bank consent lasts (max 180 by Berlin Group, GoCardless typically 90)
GOCARDLESS_CONSENT_DAYS=90
GOCARDLESS_TX_HISTORY_DAYS=730

# ─── Monitoring (optional) ────────────────────────────────────────────────
SENTRY_DSN=
